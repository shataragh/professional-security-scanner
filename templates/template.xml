# (XML - Module 3: Nmap Integration)
<?xml version="1.0" encoding="UTF-8"?>
<!--
    Module 3: Nmap Scanner Integration
    Example Nmap XML output structure parsed by the scanner
-->
<nmaprun scanner="nmap" args="-sV -sC example.com" start="1642245600">
    <host>
        <address addr="192.168.1.1" addrtype="ipv4"/>
        <ports>
            <port protocol="tcp" portid="80">
                <state state="open"/>
                <service name="http" product="Apache httpd" version="2.4.41"/>
            </port>
            <port protocol="tcp" portid="443">
                <state state="open"/>
                <service name="https" product="Apache httpd" version="2.4.41"/>
            </port>
        </ports>
    </host>
</nmaprun>
